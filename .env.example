# ─────────────────────────────────────────────────────────────────────────────
# CatchRank — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Weather APIs
VITE_WEATHER_API_KEY=
VITE_OPENWEATHER_API_KEY=
WEATHER_API_KEY=

# Google AI / Gemini
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Bol.com Reporting API (DBfishing_API)
# Access: Reporting API — sales, performance, revenue data
# Register at: https://developers.bol.com
# ─────────────────────────────────────────────────────────────────────────────
BOL_REPORTING_CLIENT_ID=
BOL_REPORTING_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Bol.com Marketing Catalog API (DBfishing_marketing_api)
# Access: Marketing Catalog API — product catalog, affiliate links, promotions
# ─────────────────────────────────────────────────────────────────────────────
BOL_MARKETING_CLIENT_ID=
BOL_MARKETING_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Bol.com Product Feed ID
# ─────────────────────────────────────────────────────────────────────────────
BOL_PRODUCT_FEED_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Fishinn / TradeTracker Affiliate Feed
# JSON product feed via TradeTracker
# aid = affiliate ID, fid = feed ID
# ─────────────────────────────────────────────────────────────────────────────
FISHINN_FEED_URL=https://pf.tradetracker.net/?aid=YOUR_AID&encoding=utf-8&type=json&fid=YOUR_FID&categoryType=2&additionalType=2
TRADETRACKER_AID=
TRADETRACKER_FISHINN_FID=
