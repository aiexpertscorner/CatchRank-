rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* ------------------------------------------------------------------ */
    /* Migrated legacy paths (flat structure from Flutter app migration)   */
    /* READ-ONLY for authenticated users — no client writes allowed        */
    /* ------------------------------------------------------------------ */
    match /assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /thumbnails/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /* ------------------------------------------------------------------ */
    /* New web app paths (user-scoped)                                     */
    /* ------------------------------------------------------------------ */
    match /users/{userId}/catches/{catchId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /users/{userId}/spots/{spotId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /users/{userId}/sessions/{sessionId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
