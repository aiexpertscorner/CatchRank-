rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "j.vandenbol@gmail.com" &&
         request.auth.token.email_verified == true);
    }

    function isValidV2Catch(data) {
      return data.userId == request.auth.uid &&
             data.status in ['draft', 'complete', 'pending'];
    }

    function isValidV2Session(data) {
      return data.userId == request.auth.uid &&
             (!('type' in data) || data.type in ['live', 'retro']) &&
             (!('isActive' in data) || data.isActive is bool);
    }

    function isValidV2Spot(data) {
      return data.userId == request.auth.uid &&
             data.title is string &&
             data.title.size() > 0 &&
             data.title.size() < 100 &&
             data.privacy in ['private', 'friends', 'public'] &&
             data.lat is number &&
             data.lng is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /catches_v2/{catchId} {
      allow read: if isAuthenticated() &&
        (
          !('isPrivate' in resource.data) ||
          resource.data.isPrivate == false ||
          resource.data.userId == request.auth.uid
        );

      allow create: if isAuthenticated() && isValidV2Catch(request.resource.data);
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        isValidV2Catch(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /sessions_v2/{sessionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        (resource.data.participantIds is list && request.auth.uid in resource.data.participantIds) ||
        (resource.data.invitedUserIds is list && request.auth.uid in resource.data.invitedUserIds)
      );

      allow create: if isAuthenticated() && isValidV2Session(request.resource.data);

      allow update: if isAuthenticated() && (
        (
          (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid) &&
          isValidV2Session(request.resource.data)
        ) ||
        (
          resource.data.invitedUserIds is list &&
          request.auth.uid in resource.data.invitedUserIds &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'participantIds',
            'acceptedUserIds',
            'pendingUserIds',
            'acceptanceStateByUser',
            'updatedAt',
            'lastActivityAt'
          ])
        )
      );

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
    }

    match /spots_v2/{spotId} {
      allow read: if isAuthenticated() && (
        resource.data.privacy == 'public' ||
        resource.data.userId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.privacy == 'friends'
      );

      allow create: if isAuthenticated() && isValidV2Spot(request.resource.data);

      allow update: if isAuthenticated() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.createdBy == request.auth.uid
        ) &&
        isValidV2Spot(request.resource.data);

      allow delete: if isAuthenticated() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.createdBy == request.auth.uid
        );
    }

    match /species/{speciesId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}